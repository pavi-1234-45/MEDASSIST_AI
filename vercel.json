{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/serverless.py": {
      "runtime": "@vercel/python@4",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/serverless" },
    { "source": "/ai/(.*)", "destination": "/api/serverless" },
    { "source": "/users/(.*)", "destination": "/api/serverless" },
    { "source": "/appointments/(.*)", "destination": "/api/serverless" }
  ]
}
