# ──────────────────────────────────────────────────────────────────────
# MedAssist AI — Environment Variables
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────

# --- AI / LLM ---
AI_API_KEY=nvapi-YOUR_KEY_HERE
AI_API_BASE_URL=https://integrate.api.nvidia.com/v1
AI_MODEL_CHAT=meta/llama-3.1-70b-instruct
AI_MODEL_VOICE=openai/gpt-oss-120b

# --- External APIs ---
OPENFDA_API_KEY=YOUR_OPENFDA_KEY
DATA_GOV_IN_API_KEY=YOUR_DATA_GOV_KEY

# --- Firebase ---
# Path to your Firebase Admin SDK service account JSON file
FIREBASE_CREDENTIALS_PATH=

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- CORS ---
# Comma-separated list of allowed origins (use * for dev)
CORS_ORIGINS=["*"]

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=60

# --- Blockchain ---
BLOCKCHAIN_ENABLED=true

# --- Notifications ---
NOTIFICATION_WEBHOOK_URL=

# --- Logging ---
LOG_LEVEL=INFO

# --- Application ---
DEBUG=true
